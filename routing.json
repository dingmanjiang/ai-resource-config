  "consumption_contract": {
    "fetch": {
      "pinned_example": {
        "tag": "v3.0.0",
        "models": "https://raw.githubusercontent.com/dingmanjiang/ai-resource-config/v3.0.0/models.json",
        "routing": "https://raw.githubusercontent.com/dingmanjiang/ai-resource-config/v3.0.0/routing.json",
        "merged": "https://raw.githubusercontent.com/dingmanjiang/ai-resource-config/v3.0.0/model-map.json"
      },
      "latest": {
        "models": "https://raw.githubusercontent.com/dingmanjiang/ai-resource-config/main/models.json",
        "routing": "https://raw.githubusercontent.com/dingmanjiang/ai-resource-config/main/routing.json",
        "merged": "https://raw.githubusercontent.com/dingmanjiang/ai-resource-config/main/model-map.json"
      },
      "recommendation": "POS/消费方 fetch pinned tag 锁定 schema；schema 变更时手动升 tag。latest(main) 仅用于人查看或主动追新。"
    },
    "how": "消费方启动时 fetch models.json + routing.json（或合并产物 model-map.json）→ 本地缓存 → 按需查询 models/task_types/mcp。task_types[].model_ref 可 join models.json[model_ref] 取价格/能力/跨家报价。",
    "stale_policy": "fetch 失败/过期 → 用本地 stale snapshot 降级运行，不阻塞",
    "review_due_expired": "可告警'选型可能过期'，但不停机",
    "no_reverse_write": "消费方不反向写本仓；发现型号漂移回 PMO 提 issue，由下次 review 修 routing.json，objective 层由 sync 脚本自动跟随 models.dev",
    "cross_provider_review_rule": "reviewer 模型必须与被审 implementation 跨 provider；redline_models 强制不分流",

    "trigger_model_policy": {
      "rule": "models.json 提供 offerings[] + cost；消费者自测哪个能触发 provider usage reset",
      "rationale": "每个 provider 对免费/低价模型能否触发 reset 行为不同，HQ 无法替消费者判断",
      "consumer_responsibility": [
        "按 cheapest/offerings 排序，从最便宜开始测试",
        "验证调用后是否触发 usage reset（非仅 200 响应）",
        "若 free 模型不触发，fallback 到下一个最便宜付费模型",
        "测试结果可回报 PMO 供后续 review 参考（非强制）"
      ]
    },

    "mcp_policy": {
      "rule": "mcp[provider][] 列出 provider 提供的 MCP 资源，消费者按需启用",
      "auth_pattern": "header:{header_name}=${ENV_VAR}",
      "consumer_responsibility": [
        "自行管理 auth 凭据（ENV_VAR 在消费侧设置）",
        "按 capabilities 判断是否适用当前任务",
        "MCP 可用性不影响模型选型（失败域独立）"
      ]
    }
  }
